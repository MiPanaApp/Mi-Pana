rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Validation Helper
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection
    // Read: All authenticated users can read basic profiles (needed for marketplace)
    // Write: Users can only write their own profile, Admins can write all
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // Products Collection
    // Read: Public (anyone can browse the marketplace)
    // Write: Must be the owner to edit/delete, or Admin
    // Create: Must be authenticated
    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // Reviews Collection
    // Read: Public
    // Write: Must be authenticated to review
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.reviewerId == request.auth.uid);
    }

    // Chats Collection
    // Read/Write: Only participants can access their chats
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Banners Collection
    // Read: Public
    // Write: Admin only
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
