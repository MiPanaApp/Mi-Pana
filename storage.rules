rules_version = '2';

// Craft rules based on how your app access files
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Public read, User write if authenticated and is owner
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Product images: Public read, User write if authenticated
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Generic fallback for authorized users
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
