rules_version = '2';

// Craft rules based on how your app access files
service firebase.storage {
  match /b/{bucket}/o {
    
    // Avatars: Public read, User write if authenticated and is owner
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Product images: Public read, User write if authenticated
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Verifications (Pana Verificado): Private for user and admin
    match /verifications/{userId}/{fileName} {
      // Solo el propio usuario puede subir
      allow write: if request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      // Solo el usuario y admins pueden leer
      allow read: if request.auth.uid == userId 
        || request.auth.token.email == 'grupoluminika@gmail.com'
        || request.auth.token.role == 'admin';
    }
    
    // Generic fallback for authorized users
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
